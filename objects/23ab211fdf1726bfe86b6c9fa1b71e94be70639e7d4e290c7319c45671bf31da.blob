{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "CommonJS",
    "moduleResolution": "node10",
    "allowSyntheticDefaultImports": true,
    "target": "ES2020",
    "outDir": ".",
    "ignoreDeprecations": "6.0"
  },
  "include": ["electron/**/*"],
  "exclude": ["node_modules"]
}
